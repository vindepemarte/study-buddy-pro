# Native Supertonic server defaults.
# Edit this file if another local app needs a different port or CORS policy.

HOST=127.0.0.1
PORT=7788
MODEL=supertonic-3
LOG_LEVEL=info

# Allow browser-based localhost apps to call the server.
# Keep HOST on 127.0.0.1 unless you intentionally want LAN access.
CORS=http://localhost:*,http://127.0.0.1:*

# M1 Max-friendly defaults. Override from your shell if needed.
SUPERTONIC_INTRA_OP_THREADS=8
SUPERTONIC_INTER_OP_THREADS=1
OMP_NUM_THREADS=8
OPENBLAS_NUM_THREADS=8
MKL_NUM_THREADS=8
